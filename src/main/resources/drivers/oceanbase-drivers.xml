<?xml version="1.0" encoding="UTF-8"?>
<drivers>
  <driver id="oceanbase" name="OceanBase" dialect="MySQL" driver-class="com.oceanbase.jdbc.Driver">
    <url-template name="default"
      template="jdbc:oceanbase://{host::localhost}[:{port::2881}][/{database}][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <url-template name="load balance"
      template="jdbc:oceanbase:loadbalance://&lt;\,,{host::localhost}[:{port::2881}]&gt;[/{database}][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <option name="auto-sync" value="true"/>
    <artifact id="OceanBase" rolling="true"/>
    <property name="tinyInt1isBit" value="false"/>
    <property name="yearIsDateType" value="false"/>
  </driver>
</drivers>
